# =============================================================================
# Intelligent Client Inquiry Response System - example environment file
# -----------------------------------------------------------------------------
# This file is a template. Copy it to .env and fill in your real values.
# Never commit the populated .env file. The .gitignore in this repo already
# excludes .env, but it is your responsibility to verify before pushing.
#
# The workflow itself stores its third-party credentials inside n8n's
# encrypted credential store (Google Sheets OAuth2, OpenAI API, Gmail OAuth2),
# not in environment variables. The variables below are for the n8n runtime
# when you self-host. If you run on n8n Cloud you can ignore most of this
# file; configure credentials through the n8n UI instead.
# =============================================================================

# ---- n8n runtime (self-hosted only) -----------------------------------------

# Host and protocol that n8n listens on. Use 0.0.0.0 inside a container so the
# port is reachable from the host. Use a real public hostname when behind a
# reverse proxy.
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Public URL that webhook nodes will register against. For this workflow there
# are no webhook triggers, but n8n still uses this value internally.
WEBHOOK_URL=http://localhost:5678/

# Encryption key for the n8n credential store. Generate with:
#   openssl rand -hex 32
# Do not reuse this value across environments. Losing it makes all stored
# credentials unrecoverable.
N8N_ENCRYPTION_KEY=replace-with-32-byte-hex-string

# Basic auth in front of the editor UI (recommended for any internet-reachable
# instance). Leave the user blank to disable, but do not expose an unprotected
# editor.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-with-strong-password

# Time zone used by the Schedule Trigger and any cron expressions. The Google
# Sheets Trigger in this workflow uses everyMinute polling and is not affected.
GENERIC_TIMEZONE=UTC
TZ=UTC

# ---- Optional: outbound rate limiting suggestions ---------------------------
# These are not consumed automatically. They are placeholders you can wire into
# the workflow (for example with a Wait or SplitInBatches node) when you fork
# the JSON for a high-volume deployment.
LEAD_DAILY_CAP=200
OPENAI_REQUESTS_PER_MINUTE=60

# ---- Reference values (do NOT put real secrets here) ------------------------
# Real credentials are configured in the n8n credential store, not here:
#   - Google Sheets OAuth2 (Google Sheets Trigger account)
#   - OpenAI API key      (OpenAi account)
#   - Gmail OAuth2        (Gmail account, sender identity)
